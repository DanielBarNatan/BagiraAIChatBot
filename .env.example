# Copy this file to .env and fill in your values.
# Do not commit .env to version control.

# OpenAI (required for embeddings and chat)
OPENAI_API_KEY=

# Azure DevOps (required for data ingestion)
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_ORG=BagiraSystems
AZURE_DEVOPS_PROJECT=Bagira Systems

# Optional: use if your project has multiple wikis (default = project wiki)
# AZURE_DEVOPS_WIKI_ID=
